        {
          "nodes": {
            "borderWidth": 2,
            "borderWidthSelected": 4,
            "font": {"color": "#ffffff", "size": 14}
          },
          "edges": {
            "arrows": {"to": {"enabled": true, "scaleFactor": 0.5}},
            "smooth": {"type": "curvedCW", "roundness": 0.2}
          },
          "physics": {
